ui_component_text_output
  <- sc_node_class;
  <- ui_component;;

ui_component_text_output_font
  <- sc_node_class;;

ui_component_text_output_style
  <- sc_node_class;;

@text_content = _[];;

ui_component_text_content_template =
[*
	format_plaintext _-> @text_content;;
	.._ui_element _=> nrel_content:: @text_content;;
*];;

..templateReplacementSet
-> rrel_1:.._ui_element;;

ui_component_text_content_template
-> rrel_key_sc_element: @text_content;
=> nrel_replacements_variables: ..templateReplacementSet;;

ui_component_text_output_style_italic
  <- sc_node_class;
  <- ui_component_text_output_style;
  -> nrel_css_property_representation: [font-style: italic];;

ui_component_text_output_size
  <- sc_node_class;;

ui_component_text_output_weight
  <- sc_node_class;;

ui_component_text_output_weight_100
  <- sc_node_class;
  <- ui_component_text_output_weight;
  => nrel_css_property_representation: [font-weight: 100];;

ui_component_text_output_weight_200
  <- sc_node_class;
  <- ui_component_text_output_weight;
  => nrel_css_property_representation: [font-weight: 200];;

