@string_template = [<sp-button color="{{ color }}" size="{{ size }}">{{ label }}</sp-button>];;
@string_template => nrel_system_identifier: [string_template];;

@string_template_expected_result = [<sp-button color="FCBA03" size="large">KNOPKA</sp-button>];;
@string_template_expected_result => nrel_system_identifier: [string_template_expected_result];;

replacement_values
-> rrel_1: button;;

button
<- concept_button (* => nrel_html_template: @string_template;; *);
<- color_fcba03;
<- .size_large;
=> nrel_decomposition: .button_decomposition (* -> text_field;; *);;

color_fcba03
<- concept_color;
=> nrel_hex: [FCBA03];;

.size_large
<- concept_size;
=> nrel_system_identifier: [large];;

text_field
=> nrel_content: [KNOPKA];
<- concept_output_text_field;;

@string_template => nrel_variable_template: variablesSetAddr;;
variablesSetAddr
-> variableTemplateNode;
-> variableTemplateNode2;
-> variableTemplateNode3;;

variableTemplateNode
-> rrel_variable: [color];
-> rrel_template: ostis_ui_color_template;;

@color_value = _[];;

ostis_ui_color_template =
[*
	concept_color _-> _color_class;;
	_color_class _-> _ui_element;;
	_color_class _=> nrel_hex:: @color_value;;
*];;

ostis_ui_color_template
-> rrel_key_sc_element: @color_value;
=> nrel_replacements_variables: ..templateReplacementSet;;

..templateReplacementSet
-> rrel_1: _ui_element;;

variableTemplateNode2
-> rrel_variable: [size];
-> rrel_template: templateAddr2;;

@size_value = _[];;

templateAddr2 =
[*
	concept_size _-> _size_class;;
	_size_class _-> _ui_element;;
	_size_class _=> nrel_system_identifier:: @size_value;;
*];;

templateAddr2
-> rrel_key_sc_element: @size_value;
=> nrel_replacements_variables: ..templateReplacementSet2;;

..templateReplacementSet2
-> rrel_1: _ui_element;;

variableTemplateNode3
-> rrel_variable: [label];
-> rrel_template: templateAddr3;;

@label_value = _[];;

templateAddr3 =
[*
	_ui_element _=> nrel_decomposition:: _button_decomposition;;
	_button_decomposition _-> _text_field;;
	_text_field _=> nrel_content:: @label_value;;
	_text_field _<- concept_output_text_field;;
*];;

templateAddr3
-> rrel_key_sc_element: @label_value;
=> nrel_replacements_variables: ..templateReplacementSet3;;

..templateReplacementSet3
-> rrel_1: _ui_element;;

test_action_node
<- action_evaluate_specified_string_template;
<- question;
-> rrel_1: @string_template;
-> rrel_2: replacement_values;
-> rrel_3: format_html;;

sc_node_class
-> format_html;;
