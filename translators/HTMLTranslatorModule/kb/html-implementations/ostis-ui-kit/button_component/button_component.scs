ostis_ui_kit_html_button
  <- sc_node_class;
  <- ostis_ui_kit_component;
  <- ostis_ui_component_implementation;
  <- ostis_ui_component_html_implementation;
  <= nrel_inclusion: concept_user_interface_component;;

@string_template = "file://button_component.j2";;
@string_template
  => nrel_system_identifier: [ostis_ui_kit_html_button_template];
  => nrel_variable_template: ostis_ui_button_variables;;

ostis_ui_kit_html_button => nrel_html_template: @string_template;;

ostis_ui_button_variables
-> ostis_ui_kit_button_color_variable_node;
-> ostis_ui_kit_button_size_variable_node;
-> ostis_ui_kit_button_decomposition_variable_node;;

ostis_ui_kit_button_color_variable_node
-> rrel_variable: [color];
-> rrel_template: ostis_ui_color_template;;

ostis_ui_kit_button_decomposition_variable_node
-> rrel_variable: [decomposition];
-> rrel_template: ostis_ui_decomposition_template;;
