ostis_ui_kit_html_page
  <- sc_node_class;
  <- ostis_ui_kit_component;
  <- ostis_ui_component_implementation;
  <- ostis_ui_component_html_implementation;
  <= nrel_inclusion: concept_user_interface_component;;

@ostis_ui_kit_html_page_template = "file://page_template.j2";;
@ostis_ui_kit_html_page_template
  => nrel_system_identifier: [ostis_ui_kit_html_page_template];
  => nrel_variable_template: ostis_ui_kit_html_page_variables_nodes;;

ostis_ui_kit_html_page => nrel_html_template: @ostis_ui_kit_html_page_template;;

ostis_ui_kit_html_page_variables_nodes
	-> ostis_ui_kit_html_page_decomposition_variable_node;;

ostis_ui_kit_html_page_decomposition_variable_node
-> rrel_variable: [decomposition];
-> rrel_template: ostis_ui_decomposition_template;;
