..label
	<- ostis_ui_kit_text_output;
	<- ostis_ui_kit_text_size_large;
	<- ui_component_text_output_weight_500;
	=> nrel_content: [CLICK ME] (* <- format_plaintext;; *);;

..description
	<- ostis_ui_kit_text_output;
	<- ostis_ui_kit_text_size_small;
	<- ui_component_text_output_weight_500;
	=> nrel_content: [some description] (* <- format_plaintext;; *);;

@button_decomposition = < ..label; ..description >;;

@button_decomposition <- sc_node_tuple;;

..button 
	<- ostis_ui_kit_html_button;
	<- ostis_ui_kit_color_accent;
	<- ostis_ui_kit_button_size_large;
	=> nrel_decomposition: @button_decomposition;;

test_action_node
	<- action_tranlate_sc_node_to_html;
	<- question;
	-> rrel_1: ..button;
	-> rrel_expected_result: [<div class="ostis-ui-button ostis-ui-kit-button-large" 
    style="background: #5896C0">
    
<p class="ostis-ui-text-output ostis-ui-kit-text-large" style=''>
    CLICK ME
</p>

<p class="ostis-ui-text-output ostis-ui-kit-text-small" style=''>
    some description
</p>

</div>
];;
