@string_template = [<button id="icon-button">{{ content }}</button>];;
@string_template => nrel_system_identifier: [string_template];;

@string_template_expected_result = [<button id="icon-button"><img src="/path/star.png"><img src="/path/hearth.png"><img src="/path/bigup.png"><p>shiiiet</p></button>];;
@string_template_expected_result => nrel_system_identifier: [string_template_expected_result];;

button
<- concept_button (* => nrel_html_template: @string_template;; *);
=> nrel_decomposition: .button_decomposition;;

button_decomposition = <..image1; ..image2; ..image3; ..text1>;;

concept_image
=> nrel_html_template: [<img src="{{ path }}">];
-> ..image1 (* => nrel_content: [/path/star.png];; *);
-> ..image2 (* => nrel_content: [/path/hearth.png];; *);;
-> ..image3 (* => nrel_content: [/path/bigup.png];; *);;;

concept_output_text_field
=> nrel_html_template: [<p>{{ content }}</p>];
-> ..text1 (* => nrel_content: [shiiiet];; *);;;
